# Agent's private key (create a new test wallet for Sepolia)
AGENT_PRIVATE_KEY=0x0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Sepolia testnet RPC URL (get one for free from Infura or Alchemy)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# User wallet address that will pay the agent
USER_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Minimum payment required (in wei) – example: 0.001 ETH = 1000000000000000
REQUIRED_PAYMENT=1000000000000000

# Port for the API server (default 8000)
PORT=8000

# Agent endpoint for internal use
CAP_AGENT_ENDPOINT=http://localhost:8000
